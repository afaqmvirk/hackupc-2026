GEMINI_API_KEY=
GEMINI_SWARM_MODEL=gemini-2.5-flash
GEMINI_AGGREGATOR_MODEL=gemini-2.5-flash
# Optional pacing between Gemini request starts. Raise this if you hit rate limits.
GEMINI_REQUEST_START_INTERVAL_MS=5000

# Optional. Without this, the app uses the provided CSV dataset in memory.
MONGODB_URI=
MONGODB_DB=creative_swarm_copilot
ATLAS_VECTOR_INDEX=creative_embedding_index

# Optional FastAPI helper. The web app already extracts basic image metadata with sharp.
CV_SERVICE_URL=http://127.0.0.1:8001
